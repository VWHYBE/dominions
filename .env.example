# ── LLM Provider (pilih satu atau set keduanya) ─────────────────────────────────
# Pakai OpenRouter (cloud) atau Ollama (local). Jika keduanya set, prioritas: LLM_PROVIDER > OPENROUTER > OLLAMA.
#
# Untuk pakai Ollama (setelah 'ollama serve'): uncomment baris berikut, lalu optional OLLAMA_* di bawah.
# LLM_PROVIDER=ollama
#
# LLM_PROVIDER=openrouter

# OpenRouter (jika pakai cloud)
OPENROUTER_API_KEY=sk-or-v1-...

# ── Model ────────────────────────────────────────────────────────────────────
# OPENROUTER_MODEL=qwen/qwen3-coder:free

# ── Token limit ──────────────────────────────────────────────────────────────
# Max completion tokens per agent call (default: 4096).
# Naikkan jika jawaban model terasa dipotong (contoh: 8192, 16384). Range: 256–128000.
# OPENROUTER_MAX_TOKENS=4096

# ── Budget preset ────────────────────────────────────────────────────────────
# One setting controls sort, partition, price cap, throughput & latency together.
#
#   free  → sort:price  | price cap: $0/$0      | no throughput/latency pref
#   min   → sort:price  | price cap: $0.3/$1.5  | no throughput/latency pref
#   mid   → sort:price  | price cap: $3/$15     | throughput p90≥30  latency≤15s
#   max   → sort:latency| no price cap           | throughput p90≥50  latency≤5s
#
# Default: max
OPENROUTER_BUDGET=max

# ── Fine-tune overrides (optional — override individual preset values) ────────
# These take priority over the preset when set.
# OPENROUTER_PROVIDER_SORT=latency          # price | latency | throughput
# OPENROUTER_PROVIDER_PARTITION=none        # model | none
# OPENROUTER_PREFERRED_MAX_LATENCY=5        # seconds; 0 = no preference
# OPENROUTER_PREFERRED_MIN_THROUGHPUT_P90=50 # tokens/sec; 0 = no preference
# OPENROUTER_MAX_PRICE_PROMPT=1.0           # USD/M prompt tokens
# OPENROUTER_MAX_PRICE_COMPLETION=4.0       # USD/M completion tokens

# ── Ollama / local model (jika pakai LLM_PROVIDER=ollama) ─────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# Timeout per request (ms). Agent ke-2 dst dapat konteks panjang; default 300000 (5 min) agar tidak "(No output)".
# OLLAMA_TIMEOUT_MS=300000

# ── Server ───────────────────────────────────────────────────────────────────
# PORT=3000
# Bind address: 127.0.0.1 = localhost only; 0.0.0.0 = allow access via network IP.
# HOST=127.0.0.1
# HOST=0.0.0.0

# ── Browser Relay ─────────────────────────────────────────────────────────────
# URL of the browser relay server (default: http://127.0.0.1:18792).
# Run the relay separately: npm run relay
# BROWSER_RELAY_URL=http://127.0.0.1:18792

# Port the relay server listens on (only used when you run the relay; default: 18792).
# RELAY_PORT=18792

# ── MobAI — mobile web automation ─────────────────────────────────────────────
# URL of the MobAI local HTTP API (requires MobAI desktop app running).
# Default: http://127.0.0.1:8686/api/v1
# MOBAI_BASE_URL=http://127.0.0.1:8686/api/v1
